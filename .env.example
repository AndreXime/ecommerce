# Copie para .env na raiz: cp .env.example .env

# --- db ---
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydb
POSTGRES_PORT=5432

# --- api-migrate + api ---
DATABASE_URL=postgresql://myuser:mypassword@host.docker.internal:5432/mydb

# --- api ---
API_PORTS=8080:8080
API_LISTEN_PORT=8080
API_ENV=DEV
FRONTEND_URL=http://localhost:4321
JWT_SECRET=3Sy78+dM9pcP3Zem6B6PJDaLYqWoNsoI/iAuWer41S0=
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=1d
S3_REGION=us-east-1
REDIS_URL=redis://host.docker.internal:6379
S3_ENDPOINT_URL=http://host.docker.internal:9000
S3_PUBLIC_URL=http://localhost:9000
EMAIL_SERVICE_HOST=host.docker.internal
EMAIL_SERVICE_PORT=1025

# --- web ---
PUBLIC_API_URL=http://localhost:8080
WEB_PORTS=4321:4321

# --- minio (api reutiliza MINIO_ROOT_* e MINIO_BUCKET como S3_*) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_CORS_ALLOW_ORIGIN=*
# 0.0.0.0: containers (api, minio-init) acessam via host.docker.internal. 127.0.0.1 quebra isso.
MINIO_HOST_BIND=0.0.0.0
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=files

# --- redis (api: REDIS_URL; porta do host = primeiro numero de REDIS_PORTS) ---
REDIS_PORTS=6379:6379

# --- mailpit (api: EMAIL_SERVICE_*; porta SMTP = primeiro numero de MAILPIT_SMTP_PORTS) ---
MAILPIT_SMTP_PORTS=1025:1025
MAILPIT_UI_PORTS=8025:8025
MAILPIT_MAX_MESSAGES=5000

# --- prometheus ---
PROMETHEUS_PORT=9090

# --- grafana ---
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
