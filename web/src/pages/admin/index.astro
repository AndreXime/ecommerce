---
import Layout from "@/layout/layout.astro";
import AdminDashboard from "./_components/AdminDashboard";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { serverGet } from "@/lib/serverApi";

export const prerender = false;

const cookieHeader = Astro.request.headers.get("cookie") ?? "";
if (!cookieHeader.trim()) return Astro.redirect("/login");

const { status } = await serverGet("/users", cookieHeader, { limit: 1 });

if (status === 401) return Astro.redirect(`/auth/refresh?redirect=${encodeURIComponent("/admin")}`);
if (status === 403) return Astro.redirect("/");
---

<Layout title="Painel Admin | Emporium da Tecnologia" description="Painel de administração do sistema">
    <Header hideSearch />

    <main class="page-shell flex-grow py-8 lg:py-10 min-h-[70vh]">
        <AdminDashboard client:load />
    </main>

    <Footer />
</Layout>
