---
import Layout from "@/layout/layout.astro";
import AuthComponent from "./_auth";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { serverGet } from "@/lib/serverApi";
import type { User } from "@/database/users";

export const prerender = false;

const cookieHeader = Astro.request.headers.get("cookie") ?? "";
if (cookieHeader.trim()) {
    const { data, status } = await serverGet<User>("/users/me", cookieHeader);
    if (status !== 401 && data) {
        return Astro.redirect(data.personalData.role === "ADMIN" ? "/admin" : "/perfil");
    }
}
---

<Layout title="Login | Lojas Ximenes" description="Acesse sua conta">
    <Header hideSearch />

    <main class="flex-grow page-shell py-12 flex items-center justify-center min-h-[70vh]">
        <AuthComponent client:load />
    </main>

    <Footer />
</Layout>
