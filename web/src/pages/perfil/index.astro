---
import Layout from "@/layout/layout.astro";
import AccountDashboard from "./_profile";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { serverGet } from "@/lib/serverApi";
import type { User } from "@/database/users";

export const prerender = false;

const cookieHeader = Astro.request.headers.get("cookie") ?? "";
if (!cookieHeader.trim()) return Astro.redirect("/login");

const { data: userData, status } = await serverGet<User>("/users/me", cookieHeader);
if (status === 401 || !userData) {
    return Astro.redirect(`/auth/refresh?redirect=${encodeURIComponent("/perfil")}`);
}
---

<Layout title="Minha Conta | Emporium da Tecnologia" description="Gerencie seus pedidos e dados">
    <Header hideSearch />

    <main class="page-shell flex-grow py-8 lg:py-10 min-h-[70vh]">
        <AccountDashboard client:load user={userData} />
    </main>

    <Footer />
</Layout>
