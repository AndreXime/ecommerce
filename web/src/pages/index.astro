---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Layout from "@/layout/layout.astro";
import StarRating from "@/components/StarRating";
import { serverGet } from "@/lib/serverApi";
import { formatPrice } from "@/lib/utils";
import { ArrowRight, ChevronLeft, ChevronRight } from "lucide-preact";
import type { PaginatedResponse, ProductSummary } from "@/database/productsTypes";

export const prerender = false;

const [offersRes, bestSellersRes] = await Promise.all([
	serverGet<PaginatedResponse<ProductSummary>>("/products", null, {
		limit: 4,
		sortBy: "createdAt",
		sortOrder: "desc",
	}),
	serverGet<PaginatedResponse<ProductSummary>>("/products", null, {
		limit: 6,
		sortBy: "rating",
		sortOrder: "desc",
	}),
]);

const offers = offersRes.data?.data ?? [];
const bestSellers = bestSellersRes.data?.data ?? [];
const heroProduct = offers[0];
---

<Layout
	title="Emporium da Tecnologia"
	description="Sua loja de eletrônicos com os melhores produtos em oferta. Smartphones, notebooks, acessórios e muito mais com entrega para todo o Brasil."
>
	<Header />

	<section class="page-shell py-8 lg:py-14">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center min-w-0">
			<div class="flex flex-col gap-6 min-w-0">
				<h1 class="font-display font-semibold text-display text-ink">
					Tecnologia que acompanha o seu ritmo
				</h1>
				<p class="text-md text-ink-2 max-w-prose leading-relaxed">
					Curadoria de eletrônicos com entrega para todo o Brasil. Do dia a dia ao setup completo.
				</p>
				<div class="flex flex-wrap gap-3">
					<a href="/produtos" class="btn btn-primary">Ver catálogo</a>
					{heroProduct && (
						<a href={`/produtos/${heroProduct.id}`} class="btn btn-secondary">
							Destaque da semana
						</a>
					)}
				</div>
			</div>

			{heroProduct && (
				<a
					href={`/produtos/${heroProduct.id}`}
					class="card card-interactive overflow-hidden group min-w-0"
				>
					<div class="aspect-[4/3] bg-paper-3 overflow-hidden">
						<img
							src={heroProduct.images[0]}
							alt={heroProduct.name}
							fetchpriority="high"
							loading="eager"
							decoding="async"
							class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
							style="transition-timing-function: var(--ease-out);"
						/>
					</div>
					<div class="p-5 flex items-end justify-between gap-4 min-w-0">
						<div class="min-w-0">
							<p class="text-xs font-medium text-muted uppercase tracking-wider mb-1 truncate">
								{heroProduct.tag}
							</p>
							<p class="font-semibold text-ink truncate">{heroProduct.name}</p>
							<p class="text-lg font-display font-semibold text-ink mt-1">
								{formatPrice(heroProduct.price)}
							</p>
						</div>
						<span class="btn btn-primary !py-2 !px-4 shrink-0">
							Ver <ArrowRight size={16} aria-hidden="true" />
						</span>
					</div>
				</a>
			)}
		</div>
	</section>

	<main class="page-shell flex-grow pb-16 space-y-16">
		<section>
			<div class="flex flex-col gap-2 mb-8">
				<h2 class="font-display font-semibold text-display-s text-ink">Produtos em oferta</h2>
				<p class="text-sm text-muted">Seleção recém-chegada ao catálogo</p>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
				{
					offers.map((product) => (
						<a
							href={`/produtos/${product.id}`}
							class="card card-interactive overflow-hidden flex flex-col group min-w-0"
						>
							<div class="relative aspect-square bg-paper-3 overflow-hidden">
								<img
									src={product.images[0]}
									alt={product.name}
									class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
									style="transition-timing-function: var(--ease-out);"
								/>
								{product.discountPercentage && (
									<span class="badge badge-danger absolute top-3 right-3">
										-{product.discountPercentage}%
									</span>
								)}
							</div>
							<div class="p-4 flex-grow flex flex-col gap-2 min-w-0">
								<span class="text-xs font-medium text-muted uppercase tracking-wider truncate">
									{product.tag}
								</span>
								<h3 class="font-semibold text-ink line-clamp-2">{product.name}</h3>
								<div class="flex items-center gap-2 text-star">
									<StarRating rating={product.rating} />
									<span class="text-xs text-muted">{product.reviewsCount}</span>
								</div>
								<div class="mt-auto flex items-center justify-between pt-2 gap-2">
									<span class="font-display font-semibold text-ink">{formatPrice(product.price)}</span>
									<span class="text-xs font-medium text-accent flex items-center gap-1">
										Detalhes <ArrowRight size={14} aria-hidden="true" />
									</span>
								</div>
							</div>
						</a>
					))
				}
			</div>
		</section>

		<section>
			<div class="flex flex-col gap-2 mb-8">
				<h2 class="font-display font-semibold text-display-s text-ink">Mais vendidos</h2>
				<p class="text-sm text-muted">O que os clientes mais levam</p>
			</div>

			<div class="relative group/slider">
				<button
					id="scrollLeft"
					aria-label="Rolar para a esquerda"
					class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-2 z-10 card p-2.5 text-ink-2 hover:text-accent transition-colors hidden lg:flex focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus"
				>
					<ChevronLeft size={20} aria-hidden="true" />
				</button>

				<div
					id="sliderContainer"
					role="list"
					aria-label="Produtos mais vendidos"
					class="flex overflow-x-auto gap-4 pb-2 hide-scroll scroll-smooth snap-x snap-mandatory"
				>
					{
						bestSellers.map((product) => (
							<a
								href={`/produtos/${product.id}`}
								role="listitem"
								class="snap-start w-[220px] sm:w-[252px] card card-interactive overflow-hidden flex flex-col shrink-0"
							>
								<div class="aspect-square bg-paper-3 overflow-hidden">
									<img src={product.images[0]} alt={product.name} class="w-full h-full object-cover" />
								</div>
								<div class="p-4 flex flex-col gap-2 flex-grow min-w-0">
									<span class="text-xs font-medium text-muted uppercase truncate">{product.tag}</span>
									<h3 class="font-semibold text-ink line-clamp-2">{product.name}</h3>
									<div class="flex items-center gap-2 text-star">
										<StarRating rating={product.rating} />
										<span class="text-xs text-muted">{product.reviewsCount}</span>
									</div>
									<div class="mt-auto flex justify-between items-center pt-2">
										<span class="font-display font-semibold">{formatPrice(product.price)}</span>
										<span class="text-xs text-accent font-medium">Ver</span>
									</div>
								</div>
							</a>
						))
					}
				</div>

				<button
					id="scrollRight"
					aria-label="Rolar para a direita"
					class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-2 z-10 card p-2.5 text-ink-2 hover:text-accent transition-colors hidden lg:flex focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus"
				>
					<ChevronRight size={20} aria-hidden="true" />
				</button>
			</div>
		</section>

		<section class="flex justify-center pt-4">
			<a href="/produtos" class="btn btn-primary !px-8">Ver todos os produtos</a>
		</section>
	</main>

	<script>
		const scrollContainer = document.getElementById("sliderContainer");
		const scrollLeftBtn = document.getElementById("scrollLeft");
		const scrollRightBtn = document.getElementById("scrollRight");

		if (scrollContainer && scrollLeftBtn && scrollRightBtn) {
			scrollLeftBtn.addEventListener("click", () => {
				scrollContainer.scrollBy({ left: -252, behavior: "smooth" });
			});
			scrollRightBtn.addEventListener("click", () => {
				scrollContainer.scrollBy({ left: 252, behavior: "smooth" });
			});
		}
	</script>

	<Footer />
</Layout>
