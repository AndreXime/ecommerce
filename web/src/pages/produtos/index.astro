---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Layout from "@/layout/layout.astro";
import StarRating from "@/components/StarRating";
import { serverGet } from "@/lib/serverApi";
import { formatPrice } from "@/lib/utils";
import { ArrowRight, Check, ChevronDown, ListFilter } from "lucide-preact";
import type { PaginatedResponse, ProductSummary, Category } from "@/database/productsTypes";

export const prerender = false;

const params = Astro.url.searchParams;
const currentPage = Number(params.get("page") || "1");
const searchTerm = params.get("s");
const selectedCategory = params.get("category");
const minPrice = params.get("minPrice");
const maxPrice = params.get("maxPrice");
const sort = params.get("sort");

const sortBy = sort ? "price" : "name";
const sortOrder = sort === "asc" || sort === "desc" ? sort : "asc";

const [productsRes, categoriesRes] = await Promise.all([
    serverGet<PaginatedResponse<ProductSummary>>("/products", null, {
        page: currentPage,
        limit: 12,
        search: searchTerm,
        category: selectedCategory,
        minPrice,
        maxPrice,
        sortBy,
        sortOrder,
    }),
    serverGet<Category[]>("/categories", null),
]);

const products = productsRes.data?.data ?? [];
const meta = productsRes.data?.meta ?? { page: 1, limit: 12, total: 0, totalPages: 1 };
const categories = categoriesRes.data ?? [];

const buildPageUrl = (page: number) => {
    const url = new URL(Astro.url);
    url.searchParams.set("page", String(page));
    return url.pathname + url.search;
};
---

<Layout
    title="Catálogo de Produtos | Emporium da Tecnologia"
    description="Explore nosso catálogo completo de eletrônicos. Filtre por categoria, marca e faixa de preço e encontre o produto ideal para você."
>
    <Header />

    <main class="page-shell flex-grow py-8 lg:py-10">
        <header class="mb-8">
            <h1 class="font-display font-semibold text-display-s text-ink">Catálogo</h1>
            <p class="text-sm text-muted mt-2">
                {meta.total} produto{meta.total !== 1 ? "s" : ""} · exibindo {products.length} nesta página
            </p>
        </header>

        <div class="flex flex-col lg:flex-row gap-8 min-w-0">
            <aside class="w-full lg:w-64 shrink-0 min-w-0">
                <div class="app-panel p-5 lg:sticky lg:top-28">
                    <form id="filters-form" method="GET" action="/produtos">
                        <input type="checkbox" id="filter-toggle" class="peer hidden" />

                        <label
                            for="filter-toggle"
                            class="flex lg:hidden justify-between items-center cursor-pointer select-none py-1 mb-3"
                        >
                            <span class="font-semibold text-ink flex items-center gap-2">
                                <ListFilter size={18} class="text-accent" aria-hidden="true" />
                                Filtros
                            </span>
                            <ChevronDown
                                class="text-muted transition-transform duration-300 peer-checked:rotate-180"
                                size={18}
                                aria-hidden="true"
                            />
                        </label>

                        <div class="hidden peer-checked:block lg:block space-y-5">
                            <div class="space-y-3 pb-4 border-b border-rule">
                                <span class="text-sm font-semibold text-ink hidden lg:block">Refinar busca</span>
                                <button
                                    type="submit"
                                    id="apply-filters-btn"
                                    disabled
                                    class="btn btn-primary w-full !py-2.5 disabled:opacity-40"
                                >
                                    <Check size={14} aria-hidden="true" /> Aplicar filtros
                                </button>
                                <a href="/produtos" class="block text-center text-xs text-muted hover:text-accent transition-colors">
                                    Limpar filtros
                                </a>
                            </div>

                            <div>
                                <label for="filter-search" class="block text-xs font-medium text-ink-2 mb-1.5">Buscar</label>
                                <input
                                    type="text"
                                    name="s"
                                    id="filter-search"
                                    value={searchTerm ?? ""}
                                    placeholder="Nome do produto..."
                                    class="input"
                                />
                            </div>

                            <div>
                                <label for="filter-sort" class="block text-xs font-medium text-ink-2 mb-1.5">Ordenar</label>
                                <select name="sort" id="filter-sort" class="input appearance-none cursor-pointer">
                                    <option value="" selected={!sort}>Padrão</option>
                                    <option value="asc" selected={sort === "asc"}>Menor preço</option>
                                    <option value="desc" selected={sort === "desc"}>Maior preço</option>
                                </select>
                            </div>

                            {categories.length > 0 && (
                                <details open class="group">
                                    <summary class="flex justify-between items-center font-semibold text-sm text-ink cursor-pointer mb-3 select-none list-none">
                                        Categoria
                                    </summary>
                                    <div class="space-y-2">
                                        {categories.map((cat) => (
                                            <label class="flex items-center gap-3 cursor-pointer py-1 group/opt">
                                                <input
                                                    type="radio"
                                                    name="category"
                                                    value={cat.name}
                                                    checked={selectedCategory === cat.name}
                                                    class="sr-only peer"
                                                />
                                                <span class="w-4 h-4 rounded-full border-2 border-rule-2 peer-checked:border-accent peer-checked:bg-accent flex items-center justify-center transition-colors">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-accent-ink opacity-0 peer-checked:opacity-100" />
                                                </span>
                                                <span class={`text-sm capitalize transition-colors ${selectedCategory === cat.name ? "text-ink font-medium" : "text-ink-2 group-hover/opt:text-ink"}`}>
                                                    {cat.name}
                                                </span>
                                            </label>
                                        ))}
                                    </div>
                                </details>
                            )}

                            <div>
                                <span class="block text-xs font-medium text-ink-2 mb-2">Faixa de preço (R$)</span>
                                <div class="flex items-center gap-2">
                                    <input
                                        type="number"
                                        name="minPrice"
                                        id="min-price"
                                        min="0"
                                        value={minPrice ?? ""}
                                        placeholder="Mín"
                                        class="input !py-2"
                                    />
                                    <span class="text-muted text-sm">–</span>
                                    <input
                                        type="number"
                                        name="maxPrice"
                                        id="max-price"
                                        min="0"
                                        value={maxPrice ?? ""}
                                        placeholder="Máx"
                                        class="input !py-2"
                                    />
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </aside>

            <div class="flex-grow min-w-0">
                {products.length === 0 ? (
                    <div class="app-panel p-16 text-center text-muted">Nenhum produto encontrado.</div>
                ) : (
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        {products.map((product) => (
                            <article class="card card-interactive overflow-hidden flex flex-col group min-w-0">
                                <a href={`/produtos/${product.id}`} class="relative aspect-[4/3] bg-paper-3 overflow-hidden block">
                                    <img
                                        src={product.images[0]}
                                        alt={product.name}
                                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                                        style="transition-timing-function: var(--ease-out);"
                                    />
                                    {product.isNew && (
                                        <span class="badge badge-accent absolute top-3 left-3">Novo</span>
                                    )}
                                    {product.discountPercentage && (
                                        <span class="badge badge-danger absolute top-3 right-3">-{product.discountPercentage}%</span>
                                    )}
                                </a>
                                <div class="p-4 flex flex-col gap-2 flex-grow min-w-0">
                                    <span class="text-xs font-medium text-muted uppercase tracking-wider truncate">{product.tag}</span>
                                    <h2 class="font-semibold text-ink">
                                        <a href={`/produtos/${product.id}`} class="hover:text-accent transition-colors line-clamp-2">
                                            {product.name}
                                        </a>
                                    </h2>
                                    <div class="flex items-center gap-2 text-star">
                                        <StarRating rating={product.rating} />
                                        <span class="text-xs text-muted">({product.reviewsCount})</span>
                                    </div>
                                    <div class="mt-auto flex items-center justify-between gap-3 pt-2">
                                        <span class="font-display font-semibold text-lg text-ink">{formatPrice(product.price)}</span>
                                        <a href={`/produtos/${product.id}`} class="btn btn-primary !py-2 !px-3 text-xs">
                                            Ver <ArrowRight size={14} aria-hidden="true" />
                                        </a>
                                    </div>
                                </div>
                            </article>
                        ))}
                    </div>
                )}

                {meta.totalPages > 1 && (
                    <nav class="mt-10 flex flex-wrap justify-center gap-2" aria-label="Paginação">
                        {meta.page > 1 && (
                            <a href={buildPageUrl(meta.page - 1)} class="btn btn-secondary !py-2 !px-3 text-sm">Anterior</a>
                        )}
                        {Array.from({ length: meta.totalPages }, (_, i) => i + 1).map((p) => (
                            <a
                                href={buildPageUrl(p)}
                                class={`btn !py-2 !px-3 text-sm min-w-[2.5rem] ${p === meta.page ? "btn-primary" : "btn-secondary"}`}
                                aria-current={p === meta.page ? "page" : undefined}
                            >
                                {p}
                            </a>
                        ))}
                        {meta.page < meta.totalPages && (
                            <a href={buildPageUrl(meta.page + 1)} class="btn btn-secondary !py-2 !px-3 text-sm">Próximo</a>
                        )}
                    </nav>
                )}
            </div>
        </div>
    </main>

    <script>
        const form = document.getElementById("filters-form") as HTMLFormElement;
        const submitBtn = document.getElementById("apply-filters-btn") as HTMLButtonElement;

        const getFormString = (formEl: HTMLFormElement): string => {
            const formData = new FormData(formEl);
            const entries = Array.from(formData.entries()) as [string, string][];
            return new URLSearchParams(entries).toString();
        };

        const initialStateString = getFormString(form);

        form.addEventListener("input", () => {
            submitBtn.disabled = initialStateString === getFormString(form);
        });

        form.addEventListener("submit", () => {
            form.querySelectorAll("[name]").forEach((el) => {
                const input = el as HTMLInputElement | HTMLSelectElement;
                if (!input.value || input.value.trim() === "") {
                    input.disabled = true;
                }
            });
        });
    </script>

    <Footer />
</Layout>
