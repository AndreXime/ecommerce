---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Layout from "@/layout/layout.astro";
import ProductAddToCart from "@/components/ProductAddToCart";
import WishlistButton from "@/components/WishlistButton";
import ProductReviewForm from "@/components/ProductReviewForm";
import StarRating from "@/components/StarRating";
import { serverGet } from "@/lib/serverApi";
import { calculateOldPrice, formatPrice, formatReviewDate } from "@/lib/utils";
import { BadgeCheck, ChevronDown } from "lucide-preact";
import type { ProductDetails } from "@/database/productsTypes";
import type { User } from "@/database/users";

export const prerender = false;
const { slug } = Astro.params;

const cookieHeader = Astro.request.headers.get("cookie") ?? "";
const { data: product } = await serverGet<ProductDetails>(`/products/${slug}`, cookieHeader || null);

if (!product) return Astro.redirect("/404");

let wishlisted = false;
if (cookieHeader.trim()) {
	const { data: me } = await serverGet<User>("/users/me", cookieHeader);
	wishlisted = Boolean(me?.wishlistProducts.some((p) => p.id === product.id));
}

const oldPrice = calculateOldPrice(product.price, product.discountPercentage ?? undefined);
---

<Layout title={product.name} description={product.description}>
    <Header />

    <main class="page-shell py-8 lg:py-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 mb-16 min-w-0">
            <div class="lg:col-span-7 min-w-0">
                <div class="app-panel p-4 lg:sticky lg:top-28">
                    <div class="aspect-[4/3] w-full overflow-hidden rounded-[calc(var(--radius-card)-4px)] bg-paper-3 mb-4">
                        <img
                            id="mainImage"
                            src={product.images[0]?.url}
                            alt={product.name}
                            class="w-full h-full object-cover object-center"
                        />
                    </div>

                    <div class="grid grid-cols-4 gap-3" id="thumbnails" role="list" aria-label="Galeria de imagens do produto">
                        {
                            product.images.map((image, index) => (
                                <button
                                    role="listitem"
                                    type="button"
                                    class={`thumbnail-btn aspect-square rounded-[var(--radius-input)] border overflow-hidden transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus ${index === 0 ? "border-accent ring-2 ring-accent/20" : "border-rule hover:border-rule-2"}`}
                                    aria-label={`Ver imagem ${index + 1} de ${product.images.length}`}
                                    aria-pressed={index === 0}
                                >
                                    <img
                                        src={image.url}
                                        alt={`${product.name} — imagem ${index + 1}`}
                                        class="w-full h-full object-cover pointer-events-none"
                                    />
                                </button>
                            ))
                        }
                    </div>
                </div>
            </div>

            <div class="lg:col-span-5 flex flex-col gap-6 min-w-0">
                <div>
                    <div class="flex items-start justify-between gap-3 mb-3">
                        <h1 class="font-display font-semibold text-display-s text-ink leading-tight">{product.name}</h1>
                        <WishlistButton
                            client:idle
                            productId={product.id}
                            initialWishlisted={wishlisted}
                            className="w-10 h-10 shrink-0"
                        />
                    </div>
                    <div class="flex flex-wrap items-center gap-3 text-sm">
                        <div class="flex items-center text-star">
                            <StarRating rating={product.rating} />
                        </div>
                        <a href="#reviews" class="text-accent font-medium hover:underline">
                            {product.reviewsCount} avaliações
                        </a>
                        <span class="text-rule-2">|</span>
                        <span class="text-success font-medium flex items-center gap-1">
                            <BadgeCheck size={16} aria-hidden="true" /> Em estoque
                        </span>
                    </div>
                </div>

                <div class="app-panel p-5">
                    {product.discountPercentage ? (
                        <p class="text-sm text-muted line-through mb-1">{formatPrice(oldPrice)}</p>
                    ) : null}
                    <div class="flex flex-wrap items-end gap-2">
                        <span class="font-display font-semibold text-3xl text-ink">{formatPrice(product.price)}</span>
                        {product.discountPercentage ? (
                            <span class="badge badge-accent mb-1">-{product.discountPercentage}%</span>
                        ) : null}
                    </div>
                    <p class="text-xs text-muted mt-2">
                        Em até 12x de {formatPrice(product.price / 12)} sem juros
                    </p>
                </div>

                <p class="text-ink-2 leading-relaxed">{product.description}</p>

                <ProductAddToCart product={product} client:idle />

                <div class="space-y-3">
                    <details class="app-panel group overflow-hidden">
                        <summary class="flex justify-between items-center p-4 font-semibold text-ink cursor-pointer select-none hover:bg-paper-2 transition-colors">
                            Especificações técnicas
                            <ChevronDown class="text-muted group-open:rotate-180 transition-transform" size={18} aria-hidden="true" />
                        </summary>
                        <div class="px-4 pb-4 text-sm text-ink-2 border-t border-rule space-y-2">
                            {
                                Object.entries(product.specs).map(([key, value]) => {
                                    if (key === "colors" || key === "storage") return null;
                                    const label = key
                                        .replace(/([A-Z])/g, " $1")
                                        .replace(/^./, (str) => str.toUpperCase());
                                    const displayValue = Array.isArray(value) ? value.join(", ") : value;
                                    return (
                                        <div class="flex justify-between gap-4 py-2 border-b border-rule last:border-0">
                                            <span class="font-medium text-ink">{label}</span>
                                            <span>{displayValue}</span>
                                        </div>
                                    );
                                })
                            }
                        </div>
                    </details>

                    <details class="app-panel group overflow-hidden">
                        <summary class="flex justify-between items-center p-4 font-semibold text-ink cursor-pointer select-none hover:bg-paper-2 transition-colors">
                            Envio e devoluções
                            <ChevronDown class="text-muted group-open:rotate-180 transition-transform" size={18} aria-hidden="true" />
                        </summary>
                        <div class="px-4 pb-4 text-sm text-ink-2 border-t border-rule space-y-2">
                            <p>Envio expresso disponível para todo o Brasil. Prazo médio de 3 a 5 dias úteis.</p>
                            <p>Devoluções em até 30 dias, com produto na embalagem original.</p>
                        </div>
                    </details>
                </div>
            </div>
        </div>

        <section id="reviews" class="border-t border-rule pt-12">
            <h2 class="font-display font-semibold text-xl text-ink mb-8">Avaliações de clientes</h2>
            <div class="flex flex-col lg:flex-row gap-10 min-w-0">
                <div class="w-full lg:w-56 shrink-0">
                    <div class="app-panel p-6 text-center">
                        <div class="font-display font-semibold text-4xl text-ink mb-2">{product.rating}</div>
                        <div class="flex justify-center text-star mb-2">
                            <StarRating rating={product.rating} />
                        </div>
                        <p class="text-sm text-muted mb-6">Baseado em {product.reviewsCount} avaliações</p>
                        <ProductReviewForm client:idle productId={product.id} />
                    </div>
                </div>

                <div class="flex-grow space-y-6 min-w-0">
                    {
                        product.fullReviews && product.fullReviews.length > 0 ? (
                            product.fullReviews.map((review) => (
                                <article class="pb-6 border-b border-rule last:border-0">
                                    <div class="flex justify-between items-start gap-4 mb-2">
                                        <div class="flex items-center gap-3 min-w-0">
                                            {review.avatar ? (
                                                <img src={review.avatar} class="w-10 h-10 rounded-full object-cover shrink-0" alt={review.author} />
                                            ) : (
                                                <div class="w-10 h-10 rounded-full bg-accent-soft text-accent flex items-center justify-center font-semibold shrink-0">
                                                    {review.initials}
                                                </div>
                                            )}
                                            <div class="min-w-0">
                                                <h3 class="font-semibold text-sm text-ink truncate">{review.author}</h3>
                                                <StarRating rating={review.rating} />
                                            </div>
                                        </div>
                                        <time class="text-xs text-muted shrink-0" datetime={review.date}>
                                            {formatReviewDate(review.date)}
                                        </time>
                                    </div>
                                    <h4 class="font-medium text-sm text-ink mb-1">{review.title}</h4>
                                    <p class="text-sm text-ink-2 leading-relaxed">{review.content}</p>
                                </article>
                            ))
                        ) : (
                            <p class="text-sm text-muted py-4">
                                Este produto ainda não tem avaliações publicadas.
                            </p>
                        )
                    }
                    {
                        product.reviewsCount > 0 && product.fullReviews && product.fullReviews.length > 0 && (
                            <a href="#reviews" class="text-sm font-medium text-accent hover:underline">
                                Ver todas as {product.reviewsCount} avaliações
                            </a>
                        )
                    }
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<script>
    const mainImage = document.getElementById("mainImage") as HTMLImageElement;
    const buttons = document.querySelectorAll(".thumbnail-btn") as NodeListOf<HTMLButtonElement>;

    const changeImage = (button: HTMLButtonElement) => {
        const thumbImg = button.querySelector("img");
        if (!thumbImg || !mainImage) return;

        mainImage.src = thumbImg.src;
        mainImage.alt = thumbImg.alt;

        buttons.forEach((btn) => {
            btn.classList.remove("border-accent", "ring-2", "ring-accent/20");
            btn.classList.add("border-rule", "hover:border-rule-2");
            btn.setAttribute("aria-pressed", "false");
        });

        button.classList.remove("border-rule", "hover:border-rule-2");
        button.classList.add("border-accent", "ring-2", "ring-accent/20");
        button.setAttribute("aria-pressed", "true");
    };

    buttons.forEach((btn) => btn.addEventListener("click", () => changeImage(btn)));
</script>
