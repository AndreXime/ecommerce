---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Layout from "@/layout/layout.astro";
import CartPage from "./_cart";
---

<Layout
    title="Meu Carrinho | Lojas Ximenes"
    description="Revise os itens do seu carrinho, ajuste quantidades e finalize sua compra com segurança."
>
    <Header />
    <main class="page-shell flex-grow py-8 lg:py-10">
        <h1 class="font-display font-semibold text-display-s text-ink mb-8">Seu carrinho</h1>
        <CartPage client:idle />
    </main>
    <Footer />
</Layout>
