---
import {
    Headphones,
    Menu,
    Package,
    Search,
    ShoppingBag,
    User,
    X,
} from "lucide-preact";

interface Props {
    hideSearch?: boolean;
}

const { hideSearch } = Astro.props;
---

<div class="px-4 pt-3 pb-2">
    <header
        class="page-shell px-5 md:!px-10 py-3 !max-w-[68rem] mx-auto flex flex-col gap-3 rounded-[var(--radius-pill)] border border-rule bg-paper/85 backdrop-blur-md shadow-[var(--shadow-card)]"
    >
        <div class="flex items-center justify-between gap-3 min-h-11 py-1">
            <div class="flex items-center gap-2 z-10">
                <button
                    id="menu-open-btn"
                    class="lg:hidden p-2 -ml-1 text-ink-2 hover:text-ink transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus rounded-full"
                    aria-label="Abrir menu"
                    aria-expanded="false"
                    aria-controls="sidebar-menu"
                >
                    <Menu size={22} aria-hidden="true" />
                </button>

                <a
                    href="/login"
                    class="hidden lg:inline-flex items-center gap-1.5 text-sm font-medium text-ink-2 hover:text-ink transition-colors"
                >
                    <User size={16} aria-hidden="true" />
                    Conta
                </a>
            </div>

            <a
                href="/"
                class="absolute left-1/2 -translate-x-1/2 font-display font-semibold text-lg tracking-tight text-ink hover:text-accent transition-colors whitespace-nowrap"
            >
                Emporium<span class="hidden min-[400px]:inline">
                    da Tecnologia</span
                >
            </a>

            <div class="flex items-center gap-1 z-10">
                <nav class="hidden lg:flex items-center gap-1 mr-2">
                    <a
                        href="/produtos"
                        class="btn btn-ghost !py-2 !px-3 text-sm">Produtos</a
                    >
                    <a
                        href="/atendimento"
                        class="btn btn-ghost !py-2 !px-3 text-sm">Atendimento</a
                    >
                </nav>

                <a
                    href="/carrinho"
                    aria-label="Carrinho de compras"
                    class="relative p-2 text-ink-2 hover:text-accent transition-colors rounded-full focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus"
                >
                    <ShoppingBag size={22} aria-hidden="true" />
                    <span
                        id="cart-count"
                        aria-live="polite"
                        aria-label="itens no carrinho"
                        class="absolute -top-0.5 -right-0.5 bg-accent text-accent-ink text-[10px] font-bold rounded-full h-4 min-w-4 px-0.5 hidden"
                    >
                        0
                    </span>
                </a>
            </div>
        </div>

        {
            !hideSearch && (
                <form action="/produtos" method="GET" class="pb-2">
                    <div class="relative">
                        <label for="header-search" class="sr-only">
                            Buscar produtos
                        </label>
                        <Search
                            class="absolute left-4 top-1/2 -translate-y-1/2 text-muted pointer-events-none"
                            size={18}
                            aria-hidden="true"
                        />
                        <input
                            type="search"
                            name="s"
                            id="header-search"
                            class="input !rounded-[var(--radius-pill)] !pl-11 !py-2.5 bg-paper-2 border-rule w-full"
                            placeholder="Buscar produtos..."
                        />
                    </div>
                </form>
            )
        }
    </header>
</div>

<div
    id="sidebar-overlay"
    class="fixed hidden inset-0 bg-ink/40 z-[60] invisible opacity-0 transition-opacity duration-300"
>
</div>

<aside
    id="sidebar-menu"
    aria-label="Menu principal"
    inert
    class="fixed top-0 left-0 w-72 h-full bg-paper z-[70] border-r border-rule transform -translate-x-full transition-transform duration-300 flex flex-col"
    style="transition-timing-function: var(--ease-out);"
>
    <div class="p-5 border-b border-rule flex justify-between items-center">
        <span class="font-display font-semibold text-ink">Menu</span>
        <button
            id="menu-close-btn"
            class="p-2 text-muted hover:text-danger transition-colors rounded-full focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus"
            aria-label="Fechar menu"
        >
            <X size={20} aria-hidden="true" />
        </button>
    </div>

    <nav class="flex-1 overflow-y-auto py-3">
        <div
            class="px-5 pb-2 text-xs font-medium text-muted uppercase tracking-wider"
        >
            Conta
        </div>
        <a
            href="/login"
            class="flex items-center px-5 py-3 text-ink-2 hover:bg-paper-2 hover:text-ink transition-colors"
        >
            <User class="w-5 h-5 mr-3" /> Minha Conta
        </a>
        <a
            href="/carrinho"
            class="flex items-center px-5 py-3 text-ink-2 hover:bg-paper-2 hover:text-ink transition-colors"
        >
            <ShoppingBag class="w-5 h-5 mr-3" /> Meu Carrinho
        </a>

        <div
            class="mt-4 px-5 pb-2 text-xs font-medium text-muted uppercase tracking-wider"
        >
            Navegação
        </div>
        <a
            href="/produtos"
            class="flex items-center px-5 py-3 text-ink-2 hover:bg-paper-2 hover:text-ink transition-colors"
        >
            <Package class="w-5 h-5 mr-3" /> Produtos
        </a>
        <a
            href="/atendimento"
            class="flex items-center px-5 py-3 text-ink-2 hover:bg-paper-2 hover:text-ink transition-colors"
        >
            <Headphones class="w-5 h-5 mr-3" /> Atendimento
        </a>
    </nav>
</aside>

<script>
    const menuOpenBtn = document.getElementById("menu-open-btn");
    const menuCloseBtn = document.getElementById("menu-close-btn");
    const sidebarOverlay = document.getElementById("sidebar-overlay");
    const sidebarMenu = document.getElementById("sidebar-menu");

    function toggleMenu() {
        const isOpen = !sidebarMenu?.classList.contains("-translate-x-full");

        if (!isOpen) {
            sidebarMenu?.classList.remove("-translate-x-full");
            sidebarMenu?.removeAttribute("inert");
            sidebarOverlay?.classList.remove(
                "invisible",
                "opacity-0",
                "hidden",
            );
            menuOpenBtn?.setAttribute("aria-expanded", "true");
            document.body.style.overflow = "hidden";
            menuCloseBtn?.focus();
        } else {
            sidebarMenu?.classList.add("-translate-x-full");
            sidebarMenu?.setAttribute("inert", "");
            sidebarOverlay?.classList.add("invisible", "opacity-0", "hidden");
            menuOpenBtn?.setAttribute("aria-expanded", "false");
            document.body.style.overflow = "";
            menuOpenBtn?.focus();
        }
    }

    menuOpenBtn?.addEventListener("click", toggleMenu);
    menuCloseBtn?.addEventListener("click", toggleMenu);
    sidebarOverlay?.addEventListener("click", toggleMenu);
</script>
<script>
    const renderCartCount = () => {
        const cart = JSON.parse(localStorage.getItem("cart") || "[]");
        const badge = document.getElementById("cart-count");

        if (!badge) return;

        badge.innerText = String(cart.length);
        const visible = cart.length > 0;
        badge.classList.toggle("hidden", !visible);
        badge.classList.toggle("flex", visible);
        badge.classList.toggle("items-center", visible);
        badge.classList.toggle("justify-center", visible);
    };

    renderCartCount();
    window.addEventListener("cart-updated", renderCartCount);
</script>
