---
import { siInstagram, siX } from "simple-icons";
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-rule py-8">
    <div class="page-shell flex flex-col gap-6 lg:gap-4">
        <div class="flex flex-col items-center gap-4 lg:flex-row lg:justify-between lg:items-center">
            <a href="/" class="font-display font-semibold text-ink hover:text-accent transition-colors">
                Emporium da Tecnologia
            </a>

            <nav class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm text-ink-2">
                <a href="/produtos" class="hover:text-ink transition-colors">Produtos</a>
                <a href="/carrinho" class="hover:text-ink transition-colors">Carrinho</a>
                <a href="/login" class="hover:text-ink transition-colors">Conta</a>
                <a href="/atendimento" class="hover:text-ink transition-colors">Atendimento</a>
            </nav>

            <div class="flex items-center gap-3">
                <a
                    href="#"
                    aria-label="Instagram"
                    class="p-2 text-muted hover:text-ink transition-colors rounded-full focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus"
                >
                    <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current" aria-hidden="true">
                        <path d={siInstagram.path}></path>
                    </svg>
                </a>
                <a
                    href="#"
                    aria-label="X"
                    class="p-2 text-muted hover:text-ink transition-colors rounded-full focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus"
                >
                    <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current" aria-hidden="true">
                        <path d={siX.path}></path>
                    </svg>
                </a>
            </div>
        </div>

        <hr class="section-rule" />

        <p class="text-center text-xs text-muted lg:text-left">
            &copy; {year} Emporium da Tecnologia. Eletrônicos selecionados, entrega para todo o Brasil.
        </p>
    </div>
</footer>
