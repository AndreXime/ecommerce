<div
    id="toaster-container"
    class="fixed top-5 right-5 flex flex-col gap-3 z-[100] max-w-[min(100vw-2rem,20rem)]"
>
</div>

<style>
    :global(.toast) {
        background-color: var(--color-ink);
        border-left: 3px solid var(--toast-border, var(--color-accent));
        min-width: 0;
        width: 100%;
        padding: 0.875rem 1rem;
        border-radius: var(--radius-card);
        color: var(--color-accent-ink);
        font-size: var(--text-sm);
        font-weight: 500;
        box-shadow: var(--shadow-float);
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
    }

    @media (prefers-reduced-motion: no-preference) {
        :global(.toast) {
            animation: toastIn var(--dur-short) var(--ease-out) forwards;
        }
    }

    @keyframes toastIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
</style>

<script>
    import type { ToastDetail } from "@/lib/toast";

    const colors = {
        success: "var(--color-success)",
        error: "var(--color-danger)",
        info: "var(--color-accent)",
    };

    window.addEventListener("toast", (e: Event) => {
        const { message, type } = (e as CustomEvent<ToastDetail>).detail;
        const container = document.getElementById("toaster-container");

        const toast = document.createElement("div");
        toast.style.setProperty("--toast-border", colors[type]);

        toast.className = "toast";
        toast.innerHTML = `<span>${message}</span>`;

        container?.appendChild(toast);

        const removeToast = () => {
            toast.style.opacity = "0";
            toast.style.transform = "translateX(100%)";
            toast.style.transition = "opacity var(--dur-short) var(--ease-out), transform var(--dur-short) var(--ease-out)";
            setTimeout(() => toast.remove(), 220);
        };

        toast.onclick = removeToast;
        setTimeout(removeToast, 4000);
    });
</script>
